# ================================
# Banco de Dados (MySQL)
# ================================
DATABASE_URL="mysql://root:root@localhost:3306/space_defenders"

# ================================
# JWT
# ================================
# Gere uma chave segura com: openssl rand -hex 32
JWT_SECRET="sua-chave-secreta-aqui"
JWT_EXPIRES_IN="1d"

# ================================
# Seed — Admin padrão
# ================================
ADMIN_EMAIL="admin@spacedefenders.com"
ADMIN_PASSWORD="12345678"

# ================================
# OAuth — Google
# ================================
# Obtenha em: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ================================
# OAuth — GitHub
# ================================
# Obtenha em: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="http://localhost:3001/auth/github/callback"

# ================================
# OAuth — Facebook
# ================================
# Obtenha em: https://developers.facebook.com
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"

# ================================
# Resend  — Enviar Emails 
# ================================
RESEND_API_KEY=re_sua_chave_aqui
MAIL_FROM=onboarding@resend.dev
FRONTEND_URL=http://localhost:3000
