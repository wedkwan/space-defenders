generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  provider  String   @default("local")
  createdAt DateTime @default(now())
  password  String?
  role      Role     @default(USER)
  scores    Score[]
}

model Score {
  id        String   @id @default(uuid())
  score     Int
  wave      Int
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}
