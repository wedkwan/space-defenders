generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  provider  String
  createdAt DateTime @default(now())
  password  String?
  role      Role     @default(USER)
}

enum Role {
  USER
  ADMIN
}
